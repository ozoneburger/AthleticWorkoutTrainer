# Do not paste secrets into chat.
# Prefer Gmail OAuth client credentials over raw API keys.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:42813/oauth2callback

# Supabase account sync.
# Use the anon/publishable key only. Never put the service-role key in Vite env.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
VITE_AUTH_REDIRECT_URL=https://jumptrainer.vercel.app
